-- ============================================
-- Query: LAG & LEAD with WoW Growth
-- ============================================

SELECT
    week_start,
    revenue,
    LAG(revenue)  OVER (ORDER BY week_start) AS prev_week_rev,
    LEAD(revenue) OVER (ORDER BY week_start) AS next_week_rev,
    ROUND(
        100.0 * (revenue - LAG(revenue) OVER (ORDER BY week_start))
              /  LAG(revenue) OVER (ORDER BY week_start),
        1
    ) AS wow_growth
FROM weekly_revenue
ORDER BY week_start;
