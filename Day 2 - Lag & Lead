-- Used in: SQL Isn't Dead — Post 3
-- Window Functions: LAG & LEAD
-- Database: SQLite
-- ============================================

CREATE TABLE weekly_revenue (
    id          INTEGER PRIMARY KEY AUTOINCREMENT,
    week_start  TEXT NOT NULL,
    revenue     REAL NOT NULL,
    created_at  TEXT NOT NULL
);

